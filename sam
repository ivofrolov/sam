"""


def render_plots(data, period, sections, separator):
    xrange = (f"{d.timestamp():.0f}" for d in period)
    yrange = lambda range_: (str(r) if r is not None else "*" for r in range_)
    input_ = (
        "\n".join(("$DATA << EOD", data, "EOD")),
        GNUPLOT_SCRIPT_PREFACE,
        *itertools.chain.from_iterable(
            (
                f'DEVICES="{" ".join(section["devices"])}"',
                f'METRICS="{" ".join(section["metrics"])}"',
                f'XRANGE="[{":".join(xrange)}]"',
                f'YRANGE="[{":".join(yrange(section["range"]))}]"',
                f'SEP="{separator}"',
                GNUPLOT_SCRIPT_LOOP,
            )
            for section in sections
        ),
    )
    proc = subprocess.run(
        ("gnuplot",),
        input="\n".join(input_),
        capture_output=True,
        check=True,
        text=True,
    )
    return re.sub(r"<\?xml.*?\?>", "", proc.stdout)  # strip xml declaration


