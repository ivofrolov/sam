REPORT_TEMPLATE = Template("""
<article>
    <h2 class="title">$hostname</h2>
    <div class="report">$report</div>
</article>
""")

SECTION_TEMPLATE = Template("""
<section>
    <h3 class="title">$title</h3>
    <figure>$plot</figure>
</section>
""")


def render_report(executor, hosts):
    def _render(host, sections, delta):
        logging.debug("fetching metrics from %s", host)
        data = fetch_metrics(host, delta.days)
        logging.debug("rendering plot for %s", host)
        collect_stats(data, sections)
        separator = "---8---"
        output = render_plots(
            data,
            period=(datetime.now() - delta, datetime.now()),
            sections=sections,
            separator=separator,
        )
        report = ""
        for section, plot in zip(sections, output.split(separator)):
            report += SECTION_TEMPLATE.substitute(title=section["title"], plot=plot)
        return REPORT_TEMPLATE.substitute(
            hostname=extract_hostname(host),
            report=report,
        )

    delta = timedelta(days=3)
    futures = [
        executor.submit(_render, host, copy.deepcopy(SYSSTAT_METRICS), delta)
        for host in hosts
    ]
    content = ""
    for future in futures:
        content += future.result()
    logging.debug("report rendered")
    return DOCUMENT_TEMPLATE.substitute(content=content)


def extract_hostname(url):
    hostname = urllib.parse.urlsplit(url).hostname
    if not hostname:
        hostname = urllib.parse.urlsplit(f"ssh://{url}").hostname
    if not hostname:
        hostname = url
    return hostname


class Handler(BaseHTTPRequestHandler):
    def log_message(self, format, *args):
        if self._debug:
            super().log_message(format, *args)

    def do_GET(self):
        match = re.fullmatch(r"/(\d*)", self.path)
        if not match:
            self.send_response(HTTPStatus.NOT_FOUND)
            self.end_headers()
            return

        days_ago = int(match.group(1) or "0")
        try:
            body = render_report().encode()
        except Exception as exc:
            self.log_error("%s", exc)
            self.send_response(HTTPStatus.INTERNAL_SERVER_ERROR)
            self.end_headers()
            return

        self.send_response(HTTPStatus.OK)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)


def render(args):
    with concurrent.futures.ThreadPoolExecutor() as executor:
        report = render_report(executor, args.host)
    print(report)


def serve(args):
    httpd = HTTPServer((args.host, args.port), Handler)
    httpd.serve_forever()


if __name__ == "__main__":
