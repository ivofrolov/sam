def fetch_metrics(destination, days):
    sadf_command = (
        "sadf", "-p", "-U",
        "--",
        "-d", "--dev=vda",
        "-F", "MOUNT", "--fs=/",
        "-m", "TEMP",
        "-n", "DEV", "--iface=eth0",
        "-u",
        "-q", "LOAD",
        "-r",
    )  # fmt: skip
    sep = "---8---"
    input_ = [
        ("echo", sep),
        *[itertools.chain(sadf_command, (f"-{d}",)) for d in range(days, 0, -1)],
        sadf_command,
    ]
    proc = subprocess.run(
        ("ssh", "-T", "-q", destination),
        input="\n".join(map(shlex.join, input_)),
        capture_output=True,
        check=True,
        text=True,
    )
    return proc.stdout[proc.stdout.index(sep) + len(sep) + 1 :]  # skip MOTD


GNUPLOT_SCRIPT = """
set terminal svg size 300,200 font "monospace,11"
set tics font "monospace,9"
set key font "monospace,9"

set datafile separator tab
set xdata time
set timefmt "%s"

set style data fillsteps
set style fill transparent solid 0.5 noborder
set tics scale 0
set grid xtics mxtics ytics

set yrange @YRANGE

set xtics time format "%a" 1 days
set mxtics 2
set xrange @XRANGE

set key outside center top horizontal Left reverse

plot for [metric in METRICS] \
     $DATA \
     using 3:6 \
     if (stringcolumn(5) eq metric) \
     title metric
"""


def render_plot(data, period, metric_names, metric_range):
    xrange = (f"{d.timestamp():.0f}" for d in period)
    yrange = (str(r) if r is not None else "*" for r in metric_range)
    input_ = (
        "\n".join(("$DATA << EOD", data, "EOD")),
        f'METRICS="{" ".join(metric_names)}"',
        f'YRANGE="[{":".join(yrange)}]"',
        f'XRANGE="[{":".join(xrange)}]"',
        GNUPLOT_SCRIPT,
    )
    proc = subprocess.run(
        ("gnuplot",),
        input="\n".join(input_),
        capture_output=True,
        check=True,
        text=True,
    )
    return re.sub(r"<\?xml.*?\?>", "", proc.stdout)  # strip xml declaration


