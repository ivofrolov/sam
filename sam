#!/usr/bin/env python3

import argparse
from http import HTTPStatus
from http.server import HTTPServer, BaseHTTPRequestHandler
import re
import subprocess


TEMPLATE = """
<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8"/>
        <title>system activity metrics</title>
    </head>
    <body style="background-color: black; display: flex;">
        <div style="margin-left: auto; margin-right: auto;">{}</div>
    </body>
</html>
"""


def render_body(metrics):
    return TEMPLATE.format(metrics).encode()


def get_metrics(days_ago):
    args = (
        "sadf", "-T", "-g", "-O", "autoscale,oneday,showtoc,skipempty", "--",
        "-d", "--dev=sda",
        "-F", "MOUNT", "--fs=/,/media/backups",
        "-m", "TEMP",
        "-n", "DEV,EDEV", "--iface=eth0",
        "-q", "LOAD",
        "-r",
        "-u",
        f"-{days_ago}",
    )  # fmt: skip
    proc = subprocess.run(args, capture_output=True, check=True, text=True)
    return proc.stdout


class Handler(BaseHTTPRequestHandler):
    _debug = False

    @classmethod
    def with_debug(cls, value):
        cls._debug = value
        return cls

    def log_message(self, format, *args):
        if self._debug:
            super().log_message(format, *args)

    def do_GET(self):
        match = re.fullmatch(r"/(\d*)", self.path)
        if not match:
            self.send_response(HTTPStatus.NOT_FOUND)
            self.end_headers()
            return

        days_ago = match.group(1) or "0"
        try:
            body = render_body(get_metrics(days_ago))
        except Exception as exc:
            self.log_error("%s", exc)
            self.send_response(HTTPStatus.INTERNAL_SERVER_ERROR)
            self.end_headers()
            return

        self.send_response(HTTPStatus.OK)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="system activity metrics server")
    parser.add_argument(
        "-H",
        "--host",
        default="localhost",
        help="host to bind to (default: %(default)s)",
    )
    parser.add_argument(
        "-p",
        "--port",
        type=int,
        default=8000,
        help="port to bind to (default: %(default)s)",
    )
    parser.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="display more information",
    )
    args = parser.parse_args()

    httpd = HTTPServer((args.host, args.port), Handler.with_debug(args.verbose))
    httpd.serve_forever()
