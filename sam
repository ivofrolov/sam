#!/usr/bin/env python3

import argparse
from datetime import datetime, timedelta
from http import HTTPStatus
from http.server import HTTPServer, BaseHTTPRequestHandler
import os
from pathlib import Path
import re
import stat
import subprocess
from tempfile import gettempdir


TEMPLATE = """
<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8"/>
        <title>system activity metrics</title>
    </head>
    <body style="background-color: white; display: flex;">
        <div style="margin-left: auto; margin-right: auto;">{}</div>
    </body>
</html>
"""


def render_body(metrics):
    return TEMPLATE.format(metrics).encode()


def render_metrics(days_ago):
    os.putenv(
        "S_COLORS_PALETTE",
        "0=dd22dd:1=008899:2=972500:3=808000:"
        "4=531ab6:5=008900:6=3548cf:7=8f0075:"
        "8=dd22dd:9=008899:A=972500:B=808000:"
        "C=531ab6:D=008900:E=3548cf:F=b2ff1a:"
        "G=e0e0e0:H=000000:I=595959:K=ffffff:"
        "L=000000:T=2a5045:W=7f0000:X=595959",
    )
    args = (
        "sadf", "-T", "-g",
        "-O", "autoscale,customcol,oneday,showtoc,skipempty",
        "--dev=sda", "--fs=/,/media/backups", "--iface=eth0",
        "--",
        "-d",
        "-F", "MOUNT",
        "-m", "TEMP",
        "-n", "DEV,EDEV",
        "-q", "LOAD",
        "-r",
        "-u",
        f"-{days_ago}",
    )  # fmt: skip
    proc = subprocess.run(args, capture_output=True, check=True, text=True)
    return proc.stdout


def get_metrics(days_ago):
    date = datetime.now() - timedelta(days=days_ago)
    file = Path(gettempdir(), "sam", "{}.svg".format(date.date().isoformat()))
    fresh = False
    if file.exists():
        mtime = datetime.fromtimestamp(file.stat().st_mtime)
        if days_ago > 0:
            # was rendered the next day?
            fresh = mtime.date() > date.date()
        else:
            # was rendered less than minute ago?
            fresh = (date - mtime).total_seconds() < 60

    if not fresh:
        text = render_metrics(days_ago)
        if not file.parent.exists():
            file.parent.mkdir()
            file.parent.chmod(stat.S_IRWXU)
        file.write_text(text)
        file.chmod(stat.S_IRUSR | stat.S_IWUSR)
    else:
        text = file.read_text()

    return text


class Handler(BaseHTTPRequestHandler):
    _debug = False

    @classmethod
    def with_debug(cls, value):
        cls._debug = value
        return cls

    def log_message(self, format, *args):
        if self._debug:
            super().log_message(format, *args)

    def do_GET(self):
        match = re.fullmatch(r"/(\d*)", self.path)
        if not match:
            self.send_response(HTTPStatus.NOT_FOUND)
            self.end_headers()
            return

        days_ago = int(match.group(1) or "0")
        try:
            body = render_body(get_metrics(days_ago))
        except Exception as exc:
            self.log_error("%s", exc)
            self.send_response(HTTPStatus.INTERNAL_SERVER_ERROR)
            self.end_headers()
            return

        self.send_response(HTTPStatus.OK)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="system activity metrics server")
    parser.add_argument(
        "-H",
        "--host",
        default="localhost",
        help="host to bind to (default: %(default)s)",
    )
    parser.add_argument(
        "-p",
        "--port",
        type=int,
        default=8000,
        help="port to bind to (default: %(default)s)",
    )
    parser.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="display more information",
    )
    args = parser.parse_args()

    httpd = HTTPServer((args.host, args.port), Handler.with_debug(args.verbose))
    httpd.serve_forever()
