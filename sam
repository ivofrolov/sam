REPORT_TEMPLATE = Template("""
<article>
    <h2 class="title">$hostname</h2>
    <div class="report">$report</div>
</article>
""")

SECTION_TEMPLATE = Template("""
<section>
    <h3 class="title">$title</h3>
    <figure>$plot</figure>
</section>
""")


def render_report(hosts):
    delta = timedelta(days=3)
    content = ""
    for host in hosts:
        report = ""
        data = fetch_metrics(host, delta.days)
        for section in SYSSTAT_METRICS:
            plot = render_plot(
                data,
                period=(datetime.now() - delta, datetime.now()),
                metric_names=section["metrics"],
                metric_range=section["range"],
            )
            report += SECTION_TEMPLATE.substitute(title=section["title"], plot=plot)
        content += REPORT_TEMPLATE.substitute(
            hostname=extract_hostname(host),
            report=report,
        )
    return DOCUMENT_TEMPLATE.substitute(content=content)


def extract_hostname(url):
    hostname = urllib.parse.urlsplit(url).hostname
    if not hostname:
        hostname = urllib.parse.urlsplit(f"ssh://{url}").hostname
    if not hostname:
        hostname = url
    return hostname


class Handler(BaseHTTPRequestHandler):
    def log_message(self, format, *args):
        if self._debug:
            super().log_message(format, *args)

    def do_GET(self):
        match = re.fullmatch(r"/(\d*)", self.path)
        if not match:
            self.send_response(HTTPStatus.NOT_FOUND)
            self.end_headers()
            return

        days_ago = int(match.group(1) or "0")
        try:
            body = render_report().encode()
        except Exception as exc:
            self.log_error("%s", exc)
            self.send_response(HTTPStatus.INTERNAL_SERVER_ERROR)
            self.end_headers()
            return

        self.send_response(HTTPStatus.OK)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)


def render(args):
    report = render_report(args.host)
    print(report)


def serve(args):
    httpd = HTTPServer((args.host, args.port), Handler)
    httpd.serve_forever()


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="sysstat metrics renderer")

    shared_parser = argparse.ArgumentParser(add_help=False)
    shared_parser.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="display more information",
    )

    subparsers = parser.add_subparsers(title="subcommands", required=True)

    render_parser = subparsers.add_parser(
        "render",
        help="render once",
        parents=[shared_parser],
    )
    render_parser.add_argument(
        "host",
        help="hostname to fetch metrics from",
        nargs="+",
    )
    render_parser.set_defaults(func=render)

    serve_parser = subparsers.add_parser(
        "serve",
        help="run server",
        parents=[shared_parser],
    )
    serve_parser.add_argument(
        "-H",
        "--host",
        default="localhost",
        help="host to bind to (default: %(default)s)",
    )
    serve_parser.add_argument(
        "-p",
        "--port",
        type=int,
        default=8000,
        help="port to bind to (default: %(default)s)",
    )
    serve_parser.set_defaults(func=serve)

    args = parser.parse_args()

    logging.basicConfig(
        level=logging.DEBUG if args.verbose else logging.ERROR,
        format="%(message)s",
    )

    args.func(args)
