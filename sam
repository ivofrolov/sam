set yrange @YRANGE

set xtics format "%a"
set xtics 1 days
set xrange @XRANGE

set key outside center top horizontal Left reverse

plot for [metric in METRICS] \
     $DATA \
     using (column("timestamp")):(column("value")) \
     if (stringcolumn("name") eq metric) \
     title metric
"""


def render_plot(data, metric_names, metric_range, period):
    yrange = (str(r) if r is not None else "*" for r in metric_range)
    xrange = (
        f"{r.timestamp():.0f}" for r in (period - timedelta(weeks=1, days=3), period)
    )
    input_ = (
        "\n".join(("$DATA << EOD", data, "EOD")),
        f'METRICS="{" ".join(metric_names)}"',
        f'YRANGE="[{":".join(yrange)}]"',
        f'XRANGE="[{":".join(xrange)}]"',
        GNUPLOT_SCRIPT,
    )
    command = ("gnuplot",)
    logging.debug("Executing command: %s", shlex.join(command))
    proc = subprocess.run(
        command,
        input="\n".join(input_),
        capture_output=True,
        check=True,
        text=True,
    )
    return re.sub(r"<\?xml.*?\?>", "", proc.stdout)  # strip xml declaration


