def collect_stats(data, sections):
    devices = collections.defaultdict(set)
    for line in io.StringIO(data):
        _, _, _, device, metric, _ = line.split("\t")
        devices[metric].add(device)
    for section in sections:
        section["devices"] = list(sorted(devices[section["metrics"][0]]))


def fetch_metrics(destination, days):
    sadf_command = (
        "sadf", "-p", "-U",
        "--",
        "-d",
        "-F", "MOUNT",
        "-m", "TEMP",
        "-n", "DEV",
        "-u",
        "-q", "LOAD",
        "-r",
    )  # fmt: skip
    sep = "---8---"
    input_ = [
        ("echo", sep),
        *(itertools.chain(sadf_command, (f"-{d}",)) for d in range(days, 0, -1)),
        sadf_command,
    ]
    proc = subprocess.run(
        ("ssh", "-T", "-q", destination),
        input="\n".join(map(shlex.join, input_)),
        capture_output=True,
        check=True,
        text=True,
    )
    return proc.stdout[proc.stdout.index(sep) + len(sep) + 1 :]  # skip MOTD


