class SysstatCsvReader:
    def __init__(self, csvfile):
        self.reader = csv.reader(csvfile, delimiter=";")

    def __iter__(self):
        return self

    def __next__(self):
        hostname, interval, timestamp, *metrics = next(self.reader)
        if len(metrics) == 1:
            # skip dummy records
            hostname, interval, timestamp, *metrics = next(self.reader)
        if hostname.startswith("#"):
            # it's a header, get next row with values
            self.metricnames = metrics
            hostname, interval, timestamp, *metrics = next(self.reader)
        return dict(
            zip(
                ("hostname", "interval", "timestamp", *self.metricnames),
                (hostname, interval, timestamp, *metrics),
            )
        )


def extract_metrics(row, dev_field, metrics):
    if dev_field is not None and dev_field not in row:
        return
    for metric in metrics:
        if metric not in row:
            return
    for metric in metrics:
        yield dict(
            dev=row[dev_field] if dev_field is not None else None,
            name=metric,
            value=row[metric],
        )


def read_metrics(file):
    for row in SysstatCsvReader(file):
        for block in SYSSTAT_METRICS:
            for metric in extract_metrics(
                row,
                block.get("dev_field"),
                block["metrics"],
            ):
                metric.update(
                    flag=block["flag"],
                    hostname=row["hostname"],
                    timestamp=row["timestamp"],
                )
                yield metric


def fetch_metrics(host):
    command = (
        "ssh", host,
        "sadf", "-d", "-U",
        "--",
        "-d", "--dev=vda",
        "-F", "MOUNT", "--fs=/",
        "-m", "TEMP",
        "-n", "DEV", "--iface=eth0",
        "-u",
        "-q", "LOAD",
        "-r",
    )  # fmt: skip
    proc = subprocess.run(command, capture_output=True, check=True, text=True)
    return proc.stdout


def import_metrics(host):
    data = fetch_metrics(host)
    return read_metrics(io.StringIO(data, newline=""))


def export_metrics(file, metrics):
    writer = csv.writer(file, delimiter=";")
    fieldnames = ("hostname", "timestamp", "flag", "dev", "name", "value")
    writer.writerow(fieldnames)
    for row in metrics:
        writer.writerow(row[field] for field in fieldnames)


def update_metrics_cache(filename, host):
    with open(filename, mode="w", newline="") as outfile:
        metrics = import_metrics(host)
        export_metrics(outfile, metrics)


def render_plot(filename, metric_names, metric_range, period):
    yrange = (str(r) if r is not None else "*" for r in metric_range)
    xranges = [
        map(lambda r: str(int(r.timestamp())), range_)
        for range_ in (
            (period - timedelta(days=1, hours=8), period),  # day
            (period - timedelta(weeks=1, days=1), period),  # week
            (period - timedelta(weeks=4), period),  # month
            (period - timedelta(days=365), period),  # year
        )
    ]
    preface = (
        f'FILENAME="{filename}"',
        f'METRICS="{" ".join(metric_names)}"',
        f'YRANGE="[{":".join(yrange)}]"',
        f'XDRANGE="[{":".join(xranges[0])}]"',
        f'XWRANGE="[{":".join(xranges[1])}]"',
        f'XMRANGE="[{":".join(xranges[2])}]"',
        f'XYRANGE="[{":".join(xranges[3])}]"',
    )
    command = ("gnuplot", "-e", ";".join(preface), "metrics.gp")
    proc = subprocess.run(command, capture_output=True, check=True, text=True)
    return re.sub(r"<\?xml.*?\?>", "", proc.stdout)  # strip xml declaration


def render_report(host, cache_filename):
    update_metrics_cache(cache_filename, host)
    report = ""
    for section in SYSSTAT_METRICS:
        plot = render_plot(
            filename=cache_filename,
            metric_names=section["metrics"],
            metric_range=section["range"],
            period=datetime.now(),
        )
        report += SECTION_TEMPLATE.substitute(title=section["title"], plot=plot)
    return REPORT_TEMPLATE.substitute(report=report)


class Handler(BaseHTTPRequestHandler):
    def log_message(self, format, *args):
        if self._debug:
            super().log_message(format, *args)

    def do_GET(self):
        match = re.fullmatch(r"/(\d*)", self.path)
        if not match:
            self.send_response(HTTPStatus.NOT_FOUND)
            self.end_headers()
            return

        days_ago = int(match.group(1) or "0")
        try:
            body = render_report().encode()
        except Exception as exc:
            self.log_error("%s", exc)
            self.send_response(HTTPStatus.INTERNAL_SERVER_ERROR)
            self.end_headers()
            return

        self.send_response(HTTPStatus.OK)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)


def render(args):
    report = render_report(args.host, args.cache)
    print(report)


def serve(args):
    httpd = HTTPServer((args.host, args.port), Handler)
    httpd.serve_forever()


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="sysstat metrics renderer")
    parser.add_argument(
        "-c",
        "--cache",
        default="cache.csv",
        help="cache file path (default: %(default)s)",
    )
    parser.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="display more information",
    )

    subparsers = parser.add_subparsers(title="subcommands", required=True)

    render_parser = subparsers.add_parser("render", help="render once")
    render_parser.add_argument("host", help="hostname to fetch metrics from")
    render_parser.set_defaults(func=render)

    serve_parser = subparsers.add_parser("serve", help="run server")
    serve_parser.add_argument(
        "-H",
        "--host",
        default="localhost",
        help="host to bind to (default: %(default)s)",
    )
    serve_parser.add_argument(
        "-p",
        "--port",
        type=int,
        default=8000,
        help="port to bind to (default: %(default)s)",
    )
    serve_parser.set_defaults(func=serve)

    args = parser.parse_args()

    logging.basicConfig(
        level=logging.DEBUG if args.verbose else logging.ERROR,
        format="%(message)s",
    )

    args.func(args)
